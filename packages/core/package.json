{
  "name": "@figma-config/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared scraper, parser, and formatter for Figma Config 2026 data",
  "keywords": [
    "figma",
    "figma-config",
    "scraper",
    "conference"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yenlai/figma-config-llms-txt"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cacache": "^18.0.0",
    "cheerio": "^1.0.0",
    "turndown": "^7.0.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/cacache": "^17.0.2",
    "@types/node": "^25.9.3",
    "@types/turndown": "^5.0.4",
    "@vitest/coverage-v8": "^1.6.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
